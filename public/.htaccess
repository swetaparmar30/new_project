<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    RewriteCond %{THE_REQUEST} /public/([^\s?]*) [NC]
    # RewriteRule ^(.*)$ https://clarkandsonsdoors.com/%1 [R=301,L]
    RewriteRule ^(.*)$ https://nateb61.sg-host.com/%1 [R=301,L]
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/index\.php(/[^\s]*)? [NC]
    RewriteRule ^index\.php(/.*)?$ %1 [R=301,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect specific openers to parent page
RewriteRule ^residential/openers/(sentinel-360|sentinel-iii|ultra-ii-wifi|pilot-ii-with-wifi|airman-ii-with-wifi|sergeant-ii-with-wifi-and-battery-backup|corporal-ii-with-wifi)/?$ /residential/openers/ [R=301,L]


    # Redirect Trailing Slashes If Not A Folder...
    # RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteCond %{REQUEST_URI} (.+)/$
    # RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
    
    # add trailing slash
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^.*[^/]$ /$0/ [L,R=301]
    
</IfModule>
